            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="rule_donation_image_write_owner" model="ir.rule">
            <field name="name">Donation request images: write own</field>
            <field name="model_id" ref="model_x_emergelens_donation_request_image"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|', ('x_request_id.x_user_id','=',user.id), ('id','=',False)]</field>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Admin (Settings / System) puede gestionar todo -->
        <record id="rule_donation_request_admin_all" model="ir.rule">
