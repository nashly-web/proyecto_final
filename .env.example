#
# .env.example - variables para docker-compose.yml (NO subir contrasenas reales)
#

# --- SMTP (Gmail recomendado) ---------------------------------------------
# Para Gmail, crea un "App Password" y usa ese valor en SMTP_PASS.
# Host y puerto comunes:
# - SSL: smtp.gmail.com:465 (SMTP_SSL=1)
# - STARTTLS: smtp.gmail.com:587 (SMTP_STARTTLS=1)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=sosemergelens@gmail.com
SMTP_PASS=CHANGE_ME
SMTP_SSL=1
SMTP_STARTTLS=0
MAIL_FROM=sosemergelens@gmail.com
MAIL_FROM_NAME=SOS EmergeLens
ADMIN_EMAIL=sosemergelens@gmail.com

# --- Odoo (server-side) ----------------------------------------------------
# Credenciales usadas por el backend para operaciones con permisos (registro, donaciones, etc.).
# Deben coincidir con un usuario admin en Odoo.
ADMIN_ODOO_EMAIL=sosemergelens@gmail.com
ADMIN_ODOO_PASS=2408

# --- Backend (Flask) -------------------------------------------------------
SECRET_KEY=dev-insecure-secret-change-me

# --- Groq (IA) -------------------------------------------------------------
# Para habilitar LENS (IA) y transcripcion (Whisper) en el backend.
# Obtiene tu API Key en Groq y pegala aqui.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Flags de correos -----------------------------------------------------
ENABLE_EMAIL_NOTIFICATIONS=1
MED_REMINDER_EMAIL_TO_CONTACTS=1
EMERGENCY_CONTACT_ALERT_EMAIL=1
